# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic (for LLM-based rule assistant)
ANTHROPIC_API_KEY=your-anthropic-key-here

# IMPORTANT: In Supabase dashboard, add these to Authentication > URL Configuration:
# - Site URL: https://app.phylax.ai
# - Redirect URLs:
#   - https://app.phylax.ai/auth/callback
#   - http://localhost:3000/auth/callback (for local dev)
